# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ──────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://listify:listify_secret@localhost:5432/listify

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cookies ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin(s), comma-separated
FRONTEND_ORIGINS=http://localhost:5173,https://nightrunner91.github.io

# ─── External APIs ─────────────────────────────────────────────────────────────
RAWG_API_KEY=YOUR_RAWG_API_KEY_HERE
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
