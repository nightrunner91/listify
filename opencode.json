{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {
        "BROWSER": "chromium"
      }
    }
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm*": "allow",
      "node*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "echo*": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "compaction": {
    "auto": true,
    "tail_turns": 20
  },
  "experimental": {
    "disable_paste_summary": true
  }
}
