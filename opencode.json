{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {
        "BROWSER": "chromium"
      }
    }
  },
  "permission": "allow",
  "compaction": {
    "auto": true,
    "tail_turns": 20
  },
  "experimental": {
    "disable_paste_summary": true
  }
}
