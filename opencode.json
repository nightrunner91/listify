{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {
        "BROWSER": "chromium"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "npm run dev": "allow",
      "npm run build": "allow",
      "npm run lint": "allow",
      "npm run preview": "allow",
      "npx vite": "allow",
      "npx playwright": "allow",
      "git *": "allow",
      "*": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "tail_turns": 20
  }
}
